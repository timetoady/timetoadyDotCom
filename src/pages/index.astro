---
import HomeHeroVisual from '../components/HomeHeroVisual.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeHighlights } from '../data/site';
---

<BaseLayout
  title="Independent software and songcraft"
  description="timetoady is home to Codeworks and Songworks: app support, privacy pages, and a growing music release practice."
  path="/"
>
  <section class="hero-home">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">timetoady</p>
        <h1>Apps and songs from one independent studio.</h1>
        <p class="lede">
          I build Android apps and games under Codeworks, and write and release music under Songworks.
        </p>
        <div class="button-row hero-copy__actions">
          <a class="button button--primary" href="/codeworks/">Explore Codeworks</a>
          <a class="button button--ghost" href="/songworks/">Listen to Our Fortress</a>
        </div>
        <div class="hero-signals" aria-label="What timetoady is">
          <div class="hero-signal">
            <strong>Two ventures</strong>
            <span>Codeworks for software, Songworks for music</span>
          </div>
          <div class="hero-signal">
            <strong>What I build</strong>
            <span>apps, games, and AI/MCP tooling</span>
          </div>
          <div class="hero-signal">
            <strong>One person</strong>
            <span>I design, build, and ship it all</span>
          </div>
        </div>
      </div>
      <HomeHeroVisual />
    </div>
  </section>

  <section class="section-block section-block--compact">
    <div class="shell">
      <div class="venture-grid">
        <article class="panel panel--spotlight panel--codeworks">
          <p class="eyebrow">For app users</p>
          <h2>Support, developer info, and privacy.</h2>
          <p>
            Codeworks tells you who built the app, where to get support, and where the privacy policy lives.
          </p>
          <div class="button-row">
            <a class="button button--primary" href="/codeworks/">Go to Codeworks</a>
          </div>
        </article>
        <article class="panel panel--spotlight panel--songworks">
          <p class="eyebrow">For listeners</p>
          <h2>Hear the latest single, then follow.</h2>
          <p>
            Songworks is the music side. Start with "Our Fortress," then follow on Spotify, YouTube, or
            iHeartRadio for what comes next.
          </p>
          <div class="button-row">
            <a class="button button--secondary" href="/songworks/">Open Songworks</a>
          </div>
        </article>
      </div>
      <article class="panel panel--quiet home-assurance">
        <p class="eyebrow">What you can count on</p>
        <ul class="bullet-list">
          {homeHighlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
