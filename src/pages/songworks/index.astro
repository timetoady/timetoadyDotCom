---
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contact } from '../../data/contact';
import {
  songworksChannels,
  songworksFeaturedMedia,
  songworksProcess,
  songworksSummary,
} from '../../data/songworks';
---

<BaseLayout
  title="Songworks"
  description="timetoady Songworks is the music branch of the studio, focused on lyric-led songs, AI-assisted composition, mastering, and release distribution."
  path="/songworks/"
  theme="songworks"
>
  <PageHero
    eyebrow="timetoady Songworks"
    title="A release practice built from lyrics to finished distribution."
    intro={songworksSummary.description}
    theme="songworks"
  >
    <div class="button-row">
      <a class="button button--primary" href={contact.youtubeChannelUrl} target="_blank" rel="noreferrer">
        Visit YouTube channel
      </a>
      <a class="button button--ghost" href="/">Back to timetoady</a>
    </div>
  </PageHero>

  <section class="section-block">
    <div class="shell media-feature">
      <div class="media-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${songworksFeaturedMedia.youtubeId}?rel=0`}
          title={`${songworksFeaturedMedia.title} by timetoady`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
        <div class="media-caption">
          <p class="eyebrow">Featured release</p>
          <strong>{songworksFeaturedMedia.title}</strong>
          <p class="muted">Published on {songworksFeaturedMedia.publishedOn}</p>
        </div>
      </div>
      <div class="media-feature__copy">
        <article class="panel panel--spotlight panel--songworks">
          <p class="eyebrow">Featured listen</p>
          <h2>One curated media anchor is better UX than a crowded video wall.</h2>
          <p>
            Songworks works best with one highlighted song near the top of the page, then a direct path out to the
            full YouTube channel. That keeps the page focused and avoids turning the site into a cluttered embedded feed.
          </p>
          <p>{songworksFeaturedMedia.summary}</p>
          <div class="button-row">
            <a class="button button--primary" href={songworksFeaturedMedia.fallbackUrl} target="_blank" rel="noreferrer">
              Watch on YouTube
            </a>
            <a class="button button--ghost" href={contact.youtubeChannelUrl} target="_blank" rel="noreferrer">
              Open full channel
            </a>
          </div>
        </article>
        <article class="panel panel--quiet">
          <p class="eyebrow">At a glance</p>
          <h3>{songworksSummary.title}</h3>
          <p>{songworksSummary.summary}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-block section-block--tight">
    <div class="shell split-emphasis">
      <article class="panel panel--quiet panel--songworks">
        <p class="eyebrow">Process</p>
        <h2>Songworks keeps the workflow explicit.</h2>
        <p>
          The public value of this page is showing that the music side has a real method: original lyrics, AI-assisted
          composition, mastering, and then public release through established channels.
        </p>
      </article>
      <div class="process-flow">
        {
          songworksProcess.map((step, index) => (
            <article class="process-step">
              <div class="process-step__meta">
                <span class="process-step__index">{index + 1}</span>
                <h3>{step.title}</h3>
              </div>
              <p>{step.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-block section-block--tight">
    <div class="shell split-emphasis">
      <article class="panel panel--quiet">
        <p class="eyebrow">Channels</p>
        <h2>Where Songworks shows up publicly.</h2>
        <div class="channel-list">
          {
            songworksChannels.map((channel) => (
              <div>
                <h3>{channel.name}</h3>
                <p>{channel.description}</p>
                <p>
                  <a
                    href={channel.href}
                    target={channel.href.startsWith('http') ? '_blank' : undefined}
                    rel={channel.href.startsWith('http') ? 'noreferrer' : undefined}
                  >
                    Open channel
                  </a>
                </p>
              </div>
            ))
          }
        </div>
      </article>
      <article class="panel panel--quiet">
        <p class="eyebrow">Contact</p>
        <h3>Project-level inquiries and future growth.</h3>
        <ul class="bullet-list">
          <li>
            Use <a href={`mailto:${contact.generalEmail}`}>{contact.generalEmail}</a> for collaboration or general
            questions.
          </li>
          <li>The page is intentionally overview-first, with room for a later release catalog.</li>
          <li>Keeping channels and featured media separate makes future release pages easier to add cleanly.</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
