---
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contact } from '../../data/contact';
import {
  songworksChannels,
  songworksFeaturedMedia,
  songworksProcess,
  songworksSummary,
} from '../../data/songworks';
---

<BaseLayout
  title="Songworks"
  description="timetoady Songworks is the music branch of the studio, focused on lyric-led songs, AI-assisted composition, mastering, and release distribution."
  path="/songworks/"
  theme="songworks"
>
  <PageHero
    eyebrow="timetoady Songworks"
    title="Our Fortress — out now."
    intro="Original, lyric-led songs from a one-person studio. Start with the latest single, then follow wherever you listen."
    theme="songworks"
  >
    <div class="button-row">
      <a class="button button--primary" href={songworksFeaturedMedia.fallbackUrl} target="_blank" rel="noreferrer">
        Listen now
      </a>
      <a class="button button--ghost" href="/">Back to timetoady</a>
    </div>
  </PageHero>

  <section class="section-block">
    <div class="shell media-feature">
      <div class="media-frame">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${songworksFeaturedMedia.youtubeId}?rel=0`}
          title={`${songworksFeaturedMedia.title} by timetoady`}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
        <div class="media-caption">
          <p class="eyebrow">Featured release</p>
          <strong>{songworksFeaturedMedia.title}</strong>
          <p class="muted">Published on {songworksFeaturedMedia.publishedOn}</p>
        </div>
      </div>
      <div class="media-feature__copy">
        <article class="panel panel--spotlight panel--songworks">
          <p class="eyebrow">Featured listen</p>
          <h2>Our Fortress</h2>
          <p>{songworksFeaturedMedia.summary}</p>
          <div class="channel-actions">
            {songworksChannels.map((channel) => (
              <a class="button button--secondary" href={channel.href} target="_blank" rel="noreferrer">
                {channel.name === 'YouTube' ? 'Watch on YouTube' : `Follow on ${channel.name}`}
              </a>
            ))}
          </div>
        </article>
        <article class="panel panel--quiet">
          <p class="eyebrow">At a glance</p>
          <h3>{songworksSummary.title}</h3>
          <p>{songworksSummary.summary}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-block section-block--tight">
    <div class="shell split-emphasis">
      <article class="panel panel--quiet panel--songworks">
        <p class="eyebrow">Process</p>
        <h2>How a Songworks track gets made.</h2>
        <p>Every track walks the same path: write the lyrics, compose, master, release.</p>
      </article>
      <div class="process-flow">
        {
          songworksProcess.map((step, index) => (
            <article class="process-step">
              <div class="process-step__meta">
                <span class="process-step__index">{index + 1}</span>
                <h3>{step.title}</h3>
              </div>
              <p>{step.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-block section-block--tight">
    <div class="shell">
      <article class="panel panel--quiet">
        <p class="eyebrow">Contact</p>
        <h3>Collaborations and questions.</h3>
        <ul class="bullet-list">
          <li>
            Want to collaborate, license a track, or just say something nice? Email
            <a href={`mailto:${contact.generalEmail}`}>{contact.generalEmail}</a>.
          </li>
          <li>A full release catalog will land here as the songs add up.</li>
          <li>Follow on Spotify, YouTube, or iHeartRadio to catch new releases as they drop.</li>
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
