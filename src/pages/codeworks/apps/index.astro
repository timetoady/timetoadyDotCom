---
import AppCard from '../../../components/AppCard.astro';
import PageHero from '../../../components/PageHero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { apps } from '../../../data/apps';
---

<BaseLayout
  title="Codeworks Apps"
  description="Browse the current timetoady Codeworks app support pages and the shared Android support hub."
  path="/codeworks/apps/"
  theme="codeworks"
>
  <PageHero
    eyebrow="App support"
    title="Practical support entries for current and upcoming timetoady apps."
    intro="This directory is where Codeworks app support pages live. Launch starts with one shared Android support hub, then grows into dedicated entries when public app listings need more granular help."
    theme="codeworks"
    variant="split"
  >
    <div class="button-row">
      <a class="button button--primary" href="/codeworks/support/">Support contact</a>
      <a class="button button--ghost" href="/codeworks/privacy/">Privacy policy</a>
    </div>
    <div slot="aside" class="panel panel--quiet">
      <p class="eyebrow">Directory scope</p>
      <div class="fact-list">
        <div>
          <strong>{apps.length} support entry</strong>
          <span>One shared Android hub for now — small on purpose, not unfinished.</span>
        </div>
        <div>
          <strong>Shared now, specific later</strong>
          <span>When an app needs its own FAQs, it gets its own page here.</span>
        </div>
      </div>
    </div>
  </PageHero>

  <section class="section-block">
    <div class="shell">
      <div class="directory-layout">
        <div class="app-directory-list">
          {apps.map((app) => <AppCard app={app} />)}
          <article class="panel panel--quiet">
            <p class="eyebrow">Coming soon</p>
            <h3>More apps, each with its own page.</h3>
            <p>
              When an app needs its own support notes, release FAQ, or troubleshooting steps, it gets a dedicated
              page right here — listed alongside this hub.
            </p>
          </article>
        </div>
        <aside class="directory-layout__aside">
          <article class="panel panel--quiet">
            <p class="eyebrow">Where links should point</p>
            <dl class="utility-list">
              <div>
                <dt>General app support</dt>
                <dd><a href="/codeworks/support/">Use the support page</a></dd>
              </div>
              <div>
                <dt>Policy coverage</dt>
                <dd><a href="/codeworks/privacy/">Use the privacy page</a></dd>
              </div>
              <div>
                <dt>Developer identity</dt>
                <dd><a href="/codeworks/">Use the Codeworks overview</a></dd>
              </div>
            </dl>
          </article>
          <article class="panel panel--codeworks">
            <p class="eyebrow">Why it's here</p>
            <p>
              Even with one entry, this gives you a real place to land from the Play Store — a working support
              index, not a placeholder or a generic "about the company" page.
            </p>
          </article>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
