---
import AppCard from '../../../components/AppCard.astro';
import PageHero from '../../../components/PageHero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { apps } from '../../../data/apps';
---

<BaseLayout
  title="Codeworks Apps"
  description="Browse the current timetoady Codeworks app support pages and the shared Android support hub."
  path="/codeworks/apps/"
  theme="codeworks"
>
  <PageHero
    eyebrow="App support"
    title="Practical support entries for current and upcoming timetoady apps."
    intro="Support pages for timetoady's Android apps. Right now that's one shared hub covering RomajiOverlay; each app gets its own page as it ships."
    theme="codeworks"
    variant="split"
  >
    <div class="button-row">
      <a class="button button--primary" href="/codeworks/support/">Support contact</a>
      <a class="button button--ghost" href="/codeworks/privacy/">Privacy policy</a>
    </div>
    <div slot="aside" class="panel panel--quiet">
      <p class="eyebrow">Directory scope</p>
      <div class="fact-list">
        <div>
          <strong>RomajiOverlay</strong>
          <span>The current Android app — support and privacy covered by the shared hub below.</span>
        </div>
        <div>
          <strong>Room to grow</strong>
          <span>When an app needs its own FAQs, it gets its own page here.</span>
        </div>
      </div>
    </div>
  </PageHero>

  <section class="section-block">
    <div class="shell">
      <div class="app-directory-list">
        {apps.map((app) => <AppCard app={app} />)}
        <article class="panel panel--quiet">
          <p class="eyebrow">Coming soon</p>
          <p>As more apps go live, each gets its own page here.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
