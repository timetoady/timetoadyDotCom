---
import { Image } from 'astro:assets';
import AppCard from '../../components/AppCard.astro';
import PageHero from '../../components/PageHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { apps } from '../../data/apps';
import { projects } from '../../data/projects';
import headerImage from '../../assets/brand/TimeToadyHeaderLarge.png';
---

<BaseLayout
  title="Codeworks"
  description="timetoady Codeworks provides the developer-facing identity, app support, and policy pages for current and future mobile software releases."
  path="/codeworks/"
  theme="codeworks"
>
  <PageHero
    eyebrow="timetoady Codeworks"
    title="Installed one of my apps? Support and privacy start here."
    intro="Codeworks is the software side of timetoady. If an app on your phone sent you here, you're in the right place — see who published it, get support, and find the privacy policy. Below: the apps and tools I've shipped."
    theme="codeworks"
    variant="split"
  >
    <div class="button-row">
      <a class="button button--primary" href="/codeworks/apps/android-apps/">Get app support</a>
      <a class="button button--ghost" href="/codeworks/support/">Contact support</a>
    </div>
    <div slot="aside" class="panel panel--codeworks panel--dense">
      <p class="eyebrow">Who's behind this</p>
      <div class="fact-list">
        <div>
          <strong>Adam Andreason</strong>
          <span>Software engineer with front-end roots — building apps, games, and AI tooling (MCP servers, agent workflows, Android apps) under the timetoady name.</span>
        </div>
        <div>
          <strong>A real, solo operation</strong>
          <span>No publisher account, no support maze — just the person who wrote the code.</span>
        </div>
        <div>
          <strong>One email away</strong>
          <span>Support and privacy questions go straight to me and get a real answer.</span>
        </div>
      </div>
    </div>
  </PageHero>

  <section class="section-block section-block--tight">
    <div class="shell">
      <div class="section-intro section-intro--split">
        <div>
          <p class="eyebrow">Public work</p>
          <h2>What I've shipped.</h2>
        </div>
        <p class="section-intro__side">
          Public projects — code and downloads, all live now: a game, an Android accessibility tool, and the
          AI/MCP developer tooling I build with.
        </p>
      </div>
      <div class="card-grid">
        {
          projects.map((project) => (
            <article class:list={['card', project.accent && `card--${project.accent}`]}>
              <p class="eyebrow">{project.category}</p>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <p class="muted">{project.tech.join(' · ')}</p>
              <div class="button-row">
                <a
                  class="button button--secondary"
                  href={project.href}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`${project.name} on GitHub`}
                >
                  {project.hrefLabel}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="shell">
      <div class="feature-split">
        <div class="banner-frame banner-frame--wide">
          <Image src={headerImage} alt="" />
        </div>
        <div class="stack">
          <article class="panel panel--spotlight panel--codeworks">
            <p class="eyebrow">What Codeworks is for</p>
            <h2>If you installed one of my apps, start here.</h2>
            <p>Confirm who published the app on your phone, get support, and find the privacy policy.</p>
          </article>
          <div class="proof-points">
            <article class="proof-point">
              <strong>Links that stay put</strong>
              <span>Support and privacy live at fixed URLs, so a store listing never points to a dead page.</span>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-block section-block--tight">
    <div class="shell">
      <div class="section-intro section-intro--split">
        <div>
          <p class="eyebrow">App support</p>
          <h2>Android app support.</h2>
        </div>
        <p class="section-intro__side">Covers RomajiOverlay for now.</p>
      </div>
      <div class="directory-layout">
        <div class="app-directory-list">
          {apps.map((app) => <AppCard app={app} />)}
        </div>
        <aside class="directory-layout__aside">
          <article class="panel panel--quiet">
            <p class="eyebrow">Utility routes</p>
            <dl class="utility-list">
              <div>
                <dt>Support inbox</dt>
                <dd><a href="/codeworks/support/">Email-first support flow</a></dd>
              </div>
              <div>
                <dt>Privacy policy</dt>
                <dd><a href="/codeworks/privacy/">Public HTML policy page</a></dd>
              </div>
            </dl>
          </article>
        </aside>
      </div>
    </div>
  </section>

</BaseLayout>
